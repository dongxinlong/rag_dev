# ==================== LLM 配置 ====================
API_KEY=your-api-key-here
MODEL_NAME=gpt-4
BASE_URL=https://api.openai.com/v1

# ==================== Embedding 配置 ====================
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=your-api-key-here

# ==================== 视觉模型配置（Ollama） ====================
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL=minicpm-v
VISION_PROMPT=请详细描述这张图片的内容，包括文字、图表、电路等所有可见信息
VISION_MAX_CONCURRENT=2
VISION_BATCH_SIZE=5
VISION_MAX_RETRIES=3

# ==================== PostgreSQL 配置 ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=rag_backend
PG_HOST=localhost
PG_PORT=5432
PG_MIN_SIZE=5
PG_MAX_SIZE=20

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-password-here

# ==================== Celery 配置 ====================
CELERY_TIMEZONE=Asia/Shanghai
CELERY_RESULT_EXPIRES=604800
CELERY_TASK_SOFT_TIME_LIMIT=7200
CELERY_TASK_TIME_LIMIT=7500
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS=100
# Worker 进程池类型：prefork(多进程)/threads(多线程)/solo(单进程)
# Windows 建议 threads，Linux 建议 prefork
CELERY_WORKER_POOL=threads
CELERY_RETRY_DELAY=60
CELERY_MAX_RETRIES=3

# ==================== Flower 配置 ====================
FLOWER_PORT=5555
FLOWER_ADDRESS=0.0.0.0
FLOWER_BASIC_AUTH=[]
FLOWER_LOG_LEVEL=INFO

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=your-minio-user
MINIO_ROOT_PASSWORD=your-minio-password
MINIO_BUCKET=rag
MINIO_SECURE=False
MINIO_EXPIRY=86400

# ==================== JWT 配置 ====================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ==================== 限流配置 ====================
RATE_LIMIT_CAPACITY=30
RATE_LIMIT_REFILL_RATE=5.0
MAX_CONCURRENCY=20

# ==================== RAG 配置 ====================
SIMILARITY_THRESHOLD=0.5
DISTANCE_THRESHOLD=0.5
CHUNK_SIZE=80
OVERLAP_SENTENCES=2
MAX_CONTEXT_LENGTH=5000
MAX_COMPLETION_TOKENS=5000
MAX_HISTORY_MESSAGES=20

# ==================== LLM 重试配置 ====================
LLM_MAX_RETRLES=5
LLM_RETRY_DELAY=1.0
LLM_RETRY_BACKOFF=2.0
LLM_TIMEOUT=30.0
LLM_RATE_LIMIT_DELAY=5.0

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=True
