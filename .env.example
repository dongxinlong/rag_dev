# ==================== LLM 配置（小米 MiMo） ====================
API_KEY=your-api-key-here
MODEL_NAME=mimo-v2.5
BASE_URL=https://api.xiaomimimo.com/v1

# ==================== Embedding 配置（硅基流动 Qwen3） ====================
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your-siliconflow-api-key
EMBEDDING_BATCH_SIZE=500

# ==================== 视觉模型配置（硅基流动 Qwen-VL） ====================
VISION_API_FORMAT=openai
OLLAMA_BASE_URL=https://api.siliconflow.cn/v1
VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
VISION_API_KEY=your-siliconflow-api-key
VISION_PROMPT=请详细描述这张图片的内容，包括文字、图表、电路等所有可见信息
VISION_MAX_CONCURRENT=3
VISION_BATCH_SIZE=5
VISION_MAX_RETRIES=3

# ==================== MinerU API 配置 ====================
MINERU_API_TOKEN=your-mineru-api-token
MINERU_API_BASE_URL=https://mineru.net/api/v4
MINERU_MAX_CONCURRENT=10
MINERU_POLL_INTERVAL=3
MINERU_TIMEOUT=600

# ==================== PostgreSQL 配置 ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=rag_backend
PG_HOST=localhost
PG_PORT=5432
PG_MIN_SIZE=5
PG_MAX_SIZE=20

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-password-here

# ==================== Celery 配置 ====================
CELERY_TIMEZONE=Asia/Shanghai
CELERY_RESULT_EXPIRES=604800
CELERY_TASK_SOFT_TIME_LIMIT=7200
CELERY_TASK_TIME_LIMIT=7500
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS=100
CELERY_WORKER_POOL=threads
CELERY_RETRY_DELAY=60
CELERY_MAX_RETRIES=3

# ==================== Flower 配置 ====================
FLOWER_PORT=5555
FLOWER_ADDRESS=0.0.0.0
FLOWER_BASIC_AUTH=[]
FLOWER_LOG_LEVEL=INFO

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=your-minio-user
MINIO_ROOT_PASSWORD=your-minio-password
MINIO_BUCKET=rag
MINIO_SECURE=False
MINIO_EXPIRY=86400

# ==================== JWT 配置 ====================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ==================== 限流配置 ====================
RATE_LIMIT_CAPACITY=30
RATE_LIMIT_REFILL_RATE=5.0
MAX_CONCURRENCY=30

# ==================== RAG 配置 ====================
SIMILARITY_THRESHOLD=0.5
DISTANCE_THRESHOLD=0.5

# ==================== 分块配置 ====================
CHUNK_SIZE=1024
CHUNK_OVERLAP=150
CHUNK_MIN_SIZE=50
CHUNK_TRANSITION_WORDS=["但是","然而","不过","除外","此外","另外","同时"]
CHUNK_SENTENCE_PATTERNS=[。！？.!?]
MAX_CONTEXT_LENGTH=5000
MAX_COMPLETION_TOKENS=5000
MAX_HISTORY_MESSAGES=20

# ==================== LLM 重试配置 ====================
LLM_MAX_RETRLES=5
LLM_RETRY_DELAY=1.0
LLM_RETRY_BACKOFF=2.0
LLM_TIMEOUT=30.0
LLM_RATE_LIMIT_DELAY=5.0

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=True
